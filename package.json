{
  "name": "meeting-minutes-ai-web-app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "docker compose up --build",
    "backend": "uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000",
